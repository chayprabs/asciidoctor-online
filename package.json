{
  "name": "asciidoctor-online",
  "private": true,
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r --filter \"./packages/*\" build && pnpm -r typecheck",
    "test": "pnpm -r test",
    "verify:preflight": "node scripts/verify-preflight.mjs",
    "verify:samples": "node scripts/verify-samples.mjs",
    "verify:samples:dry-run": "node scripts/verify-samples.mjs --dry-run",
    "verify:runtime": "node scripts/measure-worker.mjs",
    "verify:runtime:dry-run": "node scripts/measure-worker.mjs --dry-run"
  },
  "engines": {
    "node": ">=22"
  }
}
