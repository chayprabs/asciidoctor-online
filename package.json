{
  "name": "asciidoctor-online",
  "private": true,
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r --filter \"./packages/*\" build && pnpm -r typecheck",
    "test": "pnpm -r test",
    "verify:lighthouse": "node scripts/run-lighthouse.mjs",
    "verify:lighthouse:home": "node scripts/run-lighthouse.mjs http://localhost:3000/",
    "verify:preflight": "node scripts/verify-preflight.mjs",
    "verify:ci": "node scripts/verify-ci-evidence.mjs",
    "verify:hosted:config": "node scripts/verify-hosted-config.mjs",
    "verify:hosted": "node scripts/verify-hosted.mjs",
    "verify:hosted:dry-run": "node scripts/verify-hosted.mjs --dry-run",
    "verify:report": "node scripts/write-qualification-report.mjs",
    "verify:section19": "node scripts/verify-section19.mjs",
    "verify:samples": "node scripts/verify-samples.mjs",
    "verify:samples:dry-run": "node scripts/verify-samples.mjs --dry-run",
    "verify:runtime": "node scripts/measure-worker.mjs",
    "verify:runtime:dry-run": "node scripts/measure-worker.mjs --dry-run"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "lighthouse": "^13.3.0"
  }
}
